/* pages/pid/pid.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.pid-card, .adjust-card, .preset-card, .help-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.pid-display {
  display: flex;
  justify-content: space-around;
}

.pid-item {
  text-align: center;
}

.pid-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.pid-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #2b5aed;
}

.slider-group {
  padding: 20rpx 0;
}

.slider-item {
  margin-bottom: 30rpx;
}

.slider-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.preset-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.preset-item {
  padding: 20rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 8rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.preset-item:active {
  background: #f5f5f5;
}

.preset-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.preset-value {
  font-size: 24rpx;
  color: #666;
}

.button-group {
  display: flex;
  gap: 20rpx;
  margin: 30rpx 0;
}

.btn-primary, .btn-secondary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.btn-primary {
  background: #2b5aed;
  color: white;
}

.btn-secondary {
  background: #f5f5f5;
  color: #333;
}

.help-item {
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.help-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.help-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
}
